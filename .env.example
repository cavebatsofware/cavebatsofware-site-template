# Personal Site Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================

# Port the server listens on (default: 3000)
PORT=3000

# Site domain (used for email validation and display)
SITE_DOMAIN=yourdomain.com

# Site URL (used for email verification links and landing page)
SITE_URL=https://yourdomain.com

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection details
POSTGRES_DB=personal_site
POSTGRES_USER=personal_site_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Database host (use 'localhost' for local dev, 'postgres' for Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Full connection URL (must match the POSTGRES_* vars above)
DATABASE_URL=postgresql://personal_site_user:changeme@localhost:5432/personal_site

# Test database (uses port 5433 to avoid conflicts)
TEST_POSTGRES_USER=personal_site_test_user
TEST_POSTGRES_PASSWORD=test_password
TEST_POSTGRES_DB=personal_site_test
TEST_POSTGRES_PORT=5433
TEST_DATABASE_URL=postgresql://personal_site_test_user:test_password@localhost:5433/personal_site_test

# Set to "true" and run with 'cargo run -- migrate' to run migrations
MIGRATE_DB=false

# =============================================================================
# Security Configuration
# =============================================================================

# Rate limiting - max requests per minute before blocking IP
RATE_LIMIT_PER_MINUTE=60

# How long to block IPs that exceed rate limit (minutes)
BLOCK_DURATION_MINUTES=15

# TOTP encryption key for MFA (generate with: openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=

# =============================================================================
# Access Logging
# =============================================================================

# Enable/disable access logging to database
ENABLE_ACCESS_LOGGING=true

# Log successful attempts (set false to reduce database writes)
LOG_SUCCESSFUL_ATTEMPTS=true

# =============================================================================
# AWS Configuration (for SES email and S3 storage)
# =============================================================================

# S3 bucket for document storage
S3_BUCKET_NAME=your-bucket-name

# SES email address for admin verification emails
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# Docker/ECR Deployment (optional - only needed for ECR deployment)
# =============================================================================

# ECR registry URL: <account-id>.dkr.ecr.<region>.amazonaws.com
ECR_REGISTRY_URL=

# ECR repository name
ECR_REPO_NAME=

# AWS region (default: us-east-2)
ECR_REGION=us-east-2

# =============================================================================
# Custom Public Frontend (optional)
# =============================================================================

# Path to an external Astro site to use instead of the template
# Leave empty to use the included template
PUBLIC_FRONTEND_PATH=
