# {{project-name}} Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================

# Port the server listens on (default: 3000)
PORT=3000

# Site domain (used for email validation and display)
SITE_DOMAIN=yourdomain.com

# Site URL (used for email verification links and landing page)
SITE_URL=https://yourdomain.com

# Development mode: uses socket address for IP extraction instead of
# X-Forwarded-For header. Set to "true" for local dev without a reverse proxy.
DEV_MODE=false

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection details
POSTGRES_DB={{crate_name}}
POSTGRES_USER={{crate_name}}_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Database host (use 'localhost' for local dev, 'postgres' for Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Full connection URL (must match the POSTGRES_* vars above)
DATABASE_URL=postgresql://{{crate_name}}_user:changeme@localhost:5432/{{crate_name}}

# Test database (uses port 5433 to avoid conflicts)
TEST_POSTGRES_USER={{crate_name}}_test_user
TEST_POSTGRES_PASSWORD=test_password
TEST_POSTGRES_DB={{crate_name}}_test
TEST_POSTGRES_PORT=5433
TEST_DATABASE_URL=postgresql://{{crate_name}}_test_user:test_password@localhost:5433/{{crate_name}}_test

# Set to "true" and run with 'cargo run -- migrate' to run migrations
MIGRATE_DB=false

# =============================================================================
# Security Configuration
# =============================================================================

# General rate limiting - max requests per minute before blocking IP (default: 30)
RATE_LIMIT_PER_MINUTE=60

# How long to block IPs that exceed the general rate limit, in minutes (default: 15)
BLOCK_DURATION_MINUTES=15

# Auth endpoint rate limiting - stricter limits for login/register/MFA (default: 5)
AUTH_RATE_LIMIT_PER_MINUTE=5

# How long to block IPs that exceed the auth rate limit, in minutes (default: 30)
AUTH_BLOCK_DURATION_MINUTES=30

# TOTP encryption key for MFA (generate with: openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=

# =============================================================================
# Access Logging
# =============================================================================

# Enable/disable access logging to database
ENABLE_ACCESS_LOGGING=true

# Log successful attempts (set false to reduce database writes)
LOG_SUCCESSFUL_ATTEMPTS=true

# How many days to retain access logs before automatic cleanup (default: 1)
ACCESS_LOG_RETENTION_DAYS=1

# =============================================================================
# Site Settings (initial seed values)
# =============================================================================
# These values seed the database settings table on first migration.
# After that, the Admin Settings UI is the source of truth.
# Fallback chain: DB value -> env var -> hardcoded default.

# Site name displayed in emails and pages (default: "{{project-name}}")
SITE_NAME={{project-name}}

# Contact email for form submissions (default: "contact@example.com")
CONTACT_EMAIL=contact@yourdomain.com

# =============================================================================
# AWS Configuration (for SES email and S3 storage)
# =============================================================================

# S3 bucket for document storage
S3_BUCKET_NAME=your-bucket-name

# S3-compatible endpoint URL (optional - for OCI Object Storage, MinIO, etc.)
# When not set, uses standard AWS S3 endpoints
# Example for OCI: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# Example for MinIO: http://localhost:9000
S3_ENDPOINT_URL=

# S3 region override (optional - overrides AWS_REGION for S3 only)
S3_REGION=

# Force path-style S3 addressing (set to "true" for OCI/MinIO compatibility)
S3_FORCE_PATH_STYLE=false

# SES sender email address (also seeds the "from_email" DB setting on first migration)
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# Docker/ECR Deployment (optional - only needed for ECR deployment)
# =============================================================================

# ECR registry URL: <account-id>.dkr.ecr.<region>.amazonaws.com
ECR_REGISTRY_URL=

# ECR repository name
ECR_REPO_NAME=

# AWS region (default: us-east-2)
ECR_REGION=us-east-2

# =============================================================================
# OCI Container Registry (OCIR) Deployment (optional - only needed for OCIR deployment)
# =============================================================================

# OCIR registry URL: <region>.ocir.io/<tenancy-namespace>
OCIR_REGISTRY_URL=

# OCIR repository name
OCIR_REPO_NAME=

# OCIR region (default: us-ashburn-1)
OCIR_REGION_NAME=us-ashburn-1

# OCIR login credentials
# Username format: <tenancy-namespace>/<username> or <tenancy-namespace>/oracleidentitycloudservice/<username>
OCIR_USERNAME=

# OCIR auth token (generate from OCI Console -> User Settings -> Auth Tokens)
OCIR_AUTH_TOKEN=

# =============================================================================
# OIDC Authentication (optional - for Keycloak SSO integration)
# =============================================================================

# Enable OIDC authentication (disables local password auth when true)
OIDC_ENABLED=false

# OIDC provider issuer URL (e.g., https://keycloak.example.com/realms/myrealm)
OIDC_ISSUER_URL=

# OIDC client credentials
OIDC_CLIENT_ID=headscale
OIDC_CLIENT_SECRET=

# Redirect URI (must match the OIDC provider configuration)
# e.g., https://yourdomain.com/api/admin/oidc/callback
OIDC_REDIRECT_URI=http://localhost:3000/api/admin/oidc/callback

# Scopes to request (space-separated)
OIDC_SCOPES=openid profile email

# Claim path for extracting roles from ID token (dot-separated for nested claims)
OIDC_ROLE_CLAIM=realm_access.roles

# Role name in the OIDC provider that maps to application administrator
OIDC_ADMIN_ROLE=admin

# =============================================================================
# Custom Public Frontend (optional)
# =============================================================================

# Path to an external Astro site to use instead of the built-in fallback.
# The site must have `npm run build` and output to `dist/`.
# Leave empty to serve static files from public-assets/ (if present).
PUBLIC_FRONTEND_PATH=
